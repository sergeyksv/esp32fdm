menu "ESP32 FDM Bridge Configuration"

    config WIFI_SSID
        string "WiFi SSID"
        default "myssid"
        help
            WiFi network name to connect to.

    config WIFI_PASSWORD
        string "WiFi Password"
        default "mypassword"
        help
            WiFi network password.

    config PRINTER_BAUD_RATE
        int "Default Printer Baud Rate"
        default 115200
        help
            Default baud rate for USB serial connection to the printer.

    menu "Obico Integration"

        config OBICO_SERVER_URL
            string "Obico Server URL"
            default "https://app.obico.io"
            help
                Obico server URL. Change for self-hosted instances.

        config OBICO_SNAP_INTERVAL_PRINTING
            int "Snapshot interval during printing (seconds)"
            default 10
            range 5 300
            help
                How often to upload JPEG snapshots while printing or when AI watching.

        config OBICO_SNAP_INTERVAL_IDLE
            int "Snapshot interval when idle (seconds)"
            default 120
            range 30 600
            help
                How often to upload JPEG snapshots when idle.

        config OBICO_STATUS_INTERVAL
            int "WebSocket status interval (seconds)"
            default 30
            range 10 120
            help
                How often to send printer status over WebSocket.

        config OBICO_JANUS_PROXY_HOST
            string "Janus proxy sidecar IP (empty = disabled)"
            default ""
            help
                IP address of the Linux sidecar running janus_proxy.
                Leave empty to disable WebRTC streaming relay.

        config OBICO_JANUS_PROXY_PORT
            int "Janus proxy sidecar port"
            default 17800
            range 1024 65535
            help
                TCP port for the Janus signaling relay connection to sidecar.

    endmenu

    menu "RFC 2217"

        config RFC2217_PORT
            int "RFC 2217 TCP Port"
            default 2217
            range 1 65535
            help
                TCP port for the RFC 2217 serial bridge server.

    endmenu

endmenu
